  "devDependencies": {
    "eslint": "^8.56.0",
    "prettier": "^3.1.0"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^16.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  }
