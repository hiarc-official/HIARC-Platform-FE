    "clsx": "^2.0.0",
    "lucide-react": "^0.263.1",
    "react-datepicker": "^8.4.0",
    "tailwind-merge": "^1.14.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.0",
    "typescript": "^5.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "@types/react": "^18.2.0 || ^19.0.0",
    "@types/react-dom": "^18.2.0 || ^19.0.0",
    "react-hook-form": "^7.60.0"
